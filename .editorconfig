# Shared editor defaults. VS Code needs the EditorConfig extension to honor this
# (see .vscode/extensions.json); the settings in .vscode/settings.json mirror it
# so the important cases still work without the extension installed.
root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.java]
indent_size = 2
max_line_length = 120

[*.{yml,yaml,json,jsonc}]
indent_size = 2

[*.xml]
indent_size = 4

[*.md]
# Two trailing spaces are a hard line break in Markdown
trim_trailing_whitespace = false

[*.{sh,bash}]
# The git hooks must stay LF or their shebang breaks on Windows checkouts;
# .gitattributes enforces this on the git side, this keeps editors in line
end_of_line = lf
